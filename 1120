<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>北海道博美之旅 2026</title>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans TC', sans-serif; background-color: #E2F0D9; margin: 0; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .banner-box { width: 100%; background-color: #A5D8FF; line-height: 0; }
        .banner-img { width: 100%; display: block; }
        .main-content { background-color: #E2F0D9; border-radius: 35px 35px 0 0; margin-top: -30px; position: relative; z-index: 10; padding: 20px 16px; }
        .tab-bar { display: flex; justify-content: space-around; background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); border-radius: 20px; padding: 10px; margin-bottom: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

<div id="app" class="max-w-md mx-auto min-h-screen relative shadow-2xl overflow-x-hidden">
    
    <div class="banner-box">
        <img src="S__457515012_0.jpg" alt="Travel Banner" class="banner-img">
    </div>

    <main class="main-content">
        <nav class="tab-bar">
            <button v-for="tab in tabs" :key="tab.id" @click="activeTab = tab.id"
                    :class="['p-3 rounded-2xl transition-all', activeTab === tab.id ? 'bg-pink-400 text-white' : 'text-pink-300']">
                <i :data-lucide="tab.icon" class="w-6 h-6"></i>
            </button>
        </nav>

        <div v-if="activeTab === 'itinerary'">
            <div class="flex overflow-x-auto space-x-3 mb-6 pb-2 hide-scrollbar">
                <div v-for="d in dates" :key="d.date" @click="selectedDate = d.date"
                     :class="['flex flex-col items-center min-w-[65px] py-3 rounded-2xl cursor-pointer', 
                              selectedDate === d.date ? 'bg-pink-400 text-white shadow-lg' : 'bg-white text-gray-400']">
                    <span class="text-[10px] font-bold">{{ d.week }}</span>
                    <span class="text-xl font-black">{{ d.dayNum }}</span>
                </div>
            </div>

            <div class="space-y-4">
                <div v-for="(item, index) in filteredItinerary" :key="index">
                    <div v-if="item.type === 'flight'" class="bg-gradient-to-br from-blue-400 to-blue-500 rounded-[30px] p-5 text-white shadow-lg mb-4">
                        <div class="flex justify-between items-center mb-4 text-[10px] font-bold tracking-widest uppercase">
                            <span>{{ item.name }}</span>
                            <i data-lucide="plane" class="w-5 h-5"></i>
                        </div>
                        <div class="flex justify-between items-center">
                            <div class="text-center">
                                <p class="text-3xl font-black">{{ item.from }}</p>
                                <p class="text-[10px] opacity-80 mt-1">TAIPEI</p>
                            </div>
                            <div class="flex-1 border-t-2 border-dashed border-white/30 mx-4 relative">
                                <i data-lucide="chevron-right" class="absolute -top-2 right-0 w-4 h-4"></i>
                            </div>
                            <div class="text-center">
                                <p class="text-3xl font-black">{{ item.to }}</p>
                                <p class="text-[10px] opacity-80 mt-1">CHITOSE</p>
                            </div>
                        </div>
                        <div class="mt-4 pt-4 border-t border-white/10 flex justify-between text-xs font-bold">
                            <span>🛫 出發 {{ item.depTime }}</span>
                            <span>🛬 抵達 {{ item.arrTime }}</span>
                        </div>
                    </div>

                    <div v-else class="bg-white rounded-[25px] p-5 shadow-sm border border-white flex justify-between items-center" @click="openMap(item.name)">
                        <div>
                            <p class="text-[10px] text-pink-400 font-bold uppercase">{{ item.time }}</p>
                            <h3 class="text-lg font-bold text-gray-800">{{ item.name }}</h3>
                            <p class="text-xs text-gray-400 mt-1">🐾 {{ item.note }}</p>
                        </div>
                        <i data-lucide="navigation" class="text-blue-400 w-5 h-5"></i>
                    </div>
                </div>
            </div>
        </div>

        <div v-if="activeTab === 'info'" class="space-y-4">
            <div class="bg-white p-6 rounded-[30px] shadow-sm text-center">
                <h3 class="font-bold text-gray-500 mb-4 tracking-widest uppercase">匯率換算 (JPY ⮕ TWD)</h3>
                <input type="number" v-model="jpy" class="w-full bg-gray-50 rounded-2xl p-4 text-2xl font-black text-gray-700 border-none mb-3 text-center" placeholder="1000">
                <div class="text-4xl font-black text-pink-500 tracking-tighter">≈ NT$ {{ (jpy * 0.21).toFixed(0) }}</div>
            </div>
        </div>
    </main>

    <button class="fixed bottom-6 right-6 w-14 h-14 bg-pink-500 text-white rounded-full shadow-2xl flex items-center justify-center z-50 hover:scale-110 transition-transform">
        <i data-lucide="plus" class="w-6 h-6"></i>
    </button>
</div>

<script>
    const { createApp, ref, computed, onMounted, nextTick } = Vue;
    createApp({
        setup() {
            const activeTab = ref('itinerary');
            const selectedDate = ref('03.29');
            const jpy = ref(1000);

            const tabs = [
                { id: 'itinerary', icon: 'map-pin' },
                { id: 'info', icon: 'info' },
                { id: 'shopping', icon: 'shopping-basket' },
                { id: 'expenses', icon: 'circle-dollar-sign' }
            ];

            const dates = [
                { week: 'Sun', dayNum: '29', date: '03.29' },
                { week: 'Mon', dayNum: '30', date: '03.30' },
                { week: 'Tue', dayNum: '31', date: '03.31' },
                { week: 'Wed', dayNum: '01', date: '04.01' },
                { week: 'Thu', dayNum: '02', date: '04.02' },
                { week: 'Fri', dayNum: '03', date: '04.03' },
                { week: 'Sat', dayNum: '04', date: '04.04' }
            ];

            const itinerary = ref([
                { 
                    date: '03.29', type: 'flight', name: '去程航班 TR892', 
                    from: 'TPE', to: 'CTS', depTime: '13:00', arrTime: '17:55'
                },
                { 
                    date: '04.04', type: 'flight', name: '回程航班', 
                    from: 'CTS', to: 'TPE', depTime: '19:10', arrTime: '22:30'
                }
            ]);

            const filteredItinerary = computed(() => itinerary.value.filter(i => i.date === selectedDate.value));
            const openMap = (q) => window.open(`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`, '_blank');

            onMounted(() => lucide.createIcons());
            Vue.watch([activeTab, selectedDate], () => nextTick(() => lucide.createIcons()));

            return { activeTab, tabs, dates, selectedDate, filteredItinerary, jpy, openMap };
        }
    }).mount('#app');
</script>
</body>
</html>
